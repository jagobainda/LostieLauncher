<UserControl x:Class="LostieLauncher.Views.Components.GameCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:LostieLauncher.Models"
             xmlns:converters="clr-namespace:LostieLauncher.Converters"
             xmlns:viewmodels="clr-namespace:LostieLauncher.ViewModels"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             x:Name="Root">

    <UserControl.Resources>
        <converters:EnumToVisibilityConverter x:Key="AvailableVisibility" TargetValue="Available" />
        <converters:EnumToVisibilityConverter x:Key="DownloadingVisibility" TargetValue="Downloading" />
        <converters:EnumToVisibilityConverter x:Key="PausedVisibility" TargetValue="Paused" />
        <converters:EnumToVisibilityConverter x:Key="DownloadedVisibility" TargetValue="Downloaded" />
        <converters:EnumToVisibilityConverter x:Key="UpdateAvailableVisibility" TargetValue="UpdateAvailable" />
        <converters:EnumToVisibilityConverter x:Key="ExtractingVisibility" TargetValue="Extracting" />
        <converters:EnumToVisibilityConverter x:Key="VerifyingIntegrityVisibility" TargetValue="VerifyingIntegrity" />
        <converters:GameDownloadArgsConverter x:Key="GameDownloadArgsConverter" />
        <converters:PercentToWidthConverter x:Key="PercentToWidthConverter" />

        <Style x:Key="CardAccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryFgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryFgHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryFgPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource OverlayMutedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="10,0" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayMediumBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayLightBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardDisabledButtonStyle" TargetType="Button" BasedOn="{StaticResource CardSecondaryButtonStyle}">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>

        <Style x:Key="CardSuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource CardAccentButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                    <Setter Property="Opacity" Value="0.85" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DownloadProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="PART_Track">
                            <Border Background="{DynamicResource OverlayLightBrush}" CornerRadius="2" />
                            <Border x:Name="PART_Indicator"
                                    Background="{DynamicResource PrimaryFgBrush}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,0,0,10">
    <Border Background="{DynamicResource SecondaryBgBrush}" CornerRadius="6" Padding="16" SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="110" Height="80"
                    CornerRadius="6"
                    Background="{DynamicResource TertiaryBgBrush}"
                    VerticalAlignment="Center"
                    ClipToBounds="True"
                    Padding="5">
                <Grid>
                    <iconPacks:PackIconMaterial Kind="Pokeball"
                                               Width="32" Height="32"
                                               Foreground="{DynamicResource OverlayMediumBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial.Style>
                            <Style TargetType="iconPacks:PackIconMaterial">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameLogo, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </iconPacks:PackIconMaterial.Style>
                    </iconPacks:PackIconMaterial>
                    <Image Source="{Binding GameLogo, ElementName=Root}"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameLogo, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,16,0">
                <TextBlock Text="{Binding GameTitle, ElementName=Root}"
                           Foreground="{DynamicResource SecondaryFgBrush}"
                           FontSize="16"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Library}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <iconPacks:PackIconMaterial Kind="Harddisk" Width="12" Height="12"
                                               Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding GameSize, ElementName=Root}"
                               Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,14,0"
                               VerticalAlignment="Center" />

                    <!-- SECCIÓN DE NÚMERO DE DESCARGAS DESHABILITADA POR EL MOMENTO -->
                    <!--<iconPacks:PackIconMaterial Kind="Download" Width="12" Height="12"
                                               Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalDownloads, ElementName=Root}"
                               Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,14,0"
                               VerticalAlignment="Center" />-->

                    <iconPacks:PackIconMaterial Kind="TagOutline" Width="12" Height="12"
                                               Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LatestVersion, ElementName=Root}"
                               Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,0,0"
                               VerticalAlignment="Center" />

                    <StackPanel Orientation="Horizontal" Margin="14,0,0,0"
                                Visibility="{Binding PlaytimeText, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}">
                        <iconPacks:PackIconMaterial Kind="ClockOutline" Width="12" Height="12"
                                                   Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PlaytimeText, ElementName=Root}"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,6,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Games}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="TagOutline" Width="12" Height="12"
                                                   Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding InstalledVersion, ElementName=Root}"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,0,0"
                                   VerticalAlignment="Center" />

                        <Border Margin="8,0,0,0" CornerRadius="3" Padding="6,2"
                                Background="{DynamicResource PrimaryFgBrush}"
                                Visibility="{Binding Tipo, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding Tipo, ElementName=Root}"
                                       Foreground="{DynamicResource SecondaryBgBrush}"
                                       FontSize="10" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUpdate, ElementName=Root}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <iconPacks:PackIconMaterial Kind="ArrowRight" Width="10" Height="10"
                                                       Foreground="{DynamicResource PrimaryFgBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,8,0" />
                            <TextBlock Text="{Binding UpdateVersion, ElementName=Root}"
                                       Foreground="{DynamicResource PrimaryFgBrush}" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                Visibility="{Binding PlaytimeText, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}">
                        <iconPacks:PackIconMaterial Kind="ClockOutline" Width="12" Height="12"
                                                   Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PlaytimeText, ElementName=Root}"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,8,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.Downloading}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.Paused}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.Extracting}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.VerifyingIntegrity}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <ProgressBar Height="4"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding DownloadProgress, ElementName=Root}"
                                 Style="{StaticResource DownloadProgressBarStyle}" />

                    <Grid Margin="0,3,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DownloadProgress, ElementName=Root, StringFormat='{}{0:0}%'}"
                                       Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.Extracting}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.VerifyingIntegrity}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding DownloadRemainingText, ElementName=Root}"
                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                       FontSize="11" Margin="4,0,0,0"
                                       Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource DownloadingVisibility}}" />
                            <TextBlock Text="{Binding Strings.StatusExtracting, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                                       Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="11"
                                       Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource ExtractingVisibility}}" />
                            <TextBlock Text="{Binding Strings.StatusVerifying, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                                       Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="11"
                                       Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource VerifyingIntegrityVisibility}}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DownloadSpeedText, ElementName=Root}"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                   FontSize="11" HorizontalAlignment="Right">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.Downloading}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Library}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Button Command="{Binding DownloadCommand, ElementName=Root}"
                            Style="{StaticResource CardAccentButtonStyle}"
                            Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource AvailableVisibility}}">
                        <Button.CommandParameter>
                            <MultiBinding Converter="{StaticResource GameDownloadArgsConverter}">
                                <Binding Path="GameId" ElementName="Root" />
                                <Binding Path="LatestVersion" ElementName="Root" />
                                <Binding Path="RutaRelativa" ElementName="Root" />
                            </MultiBinding>
                        </Button.CommandParameter>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Download" Width="13" Height="13"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Strings.BtnDownload, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource DownloadingVisibility}}">
                        <Button Command="{Binding PauseDownloadCommand, ElementName=Root}"
                                CommandParameter="{Binding GameId, ElementName=Root}"
                                Style="{StaticResource CardAccentButtonStyle}"
                                Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Pause" Width="13" Height="13"
                                                            VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Strings.BtnPause, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CancelDownloadCommand, ElementName=Root}"
                                CommandParameter="{Binding GameId, ElementName=Root}"
                                Style="{StaticResource CardSecondaryButtonStyle}"
                                ToolTip="{Binding Strings.BtnCancel, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource PausedVisibility}}">
                        <Button Command="{Binding DownloadCommand, ElementName=Root}"
                                Style="{StaticResource CardAccentButtonStyle}"
                                Margin="0,0,6,0">
                            <Button.CommandParameter>
                                <MultiBinding Converter="{StaticResource GameDownloadArgsConverter}">
                                    <Binding Path="GameId" ElementName="Root" />
                                    <Binding Path="LatestVersion" ElementName="Root" />
                                    <Binding Path="RutaRelativa" ElementName="Root" />
                                </MultiBinding>
                            </Button.CommandParameter>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Play" Width="13" Height="13"
                                                            VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Strings.BtnResume, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CancelDownloadCommand, ElementName=Root}"
                                CommandParameter="{Binding GameId, ElementName=Root}"
                                Style="{StaticResource CardSecondaryButtonStyle}"
                                ToolTip="{Binding Strings.BtnCancel, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <Button Style="{StaticResource CardDisabledButtonStyle}"
                            Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource DownloadedVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check" Width="13" Height="13"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Strings.BtnDownloaded, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding LibraryUpdateCommand, ElementName=Root}"
                            Style="{StaticResource CardSuccessButtonStyle}"
                            Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource UpdateAvailableVisibility}}">
                        <Button.CommandParameter>
                            <MultiBinding Converter="{StaticResource GameDownloadArgsConverter}">
                                <Binding Path="GameId" ElementName="Root" />
                                <Binding Path="LatestVersion" ElementName="Root" />
                                <Binding Path="RutaRelativa" ElementName="Root" />
                            </MultiBinding>
                        </Button.CommandParameter>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Update" Width="13" Height="13"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Strings.BtnUpdate, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Games}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUninstalling, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Command="{Binding PlayCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource CardAccentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpdating, ElementName=Root}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasUpdate, ElementName=Root}" Value="True" />
                                                <Condition Binding="{Binding IsSpecialVersion, ElementName=Root}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="IsEnabled" Value="False" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Play" Width="13" Height="13"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Strings.BtnPlay, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding UpdateCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource CardSuccessButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUpdate, ElementName=Root}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Update" Width="13" Height="13"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Strings.BtnUpdate, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding OpenHelpFolderCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Margin="0,0,6,0"
                                ToolTip="{Binding Strings.TooltipOpenHelp, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource CardSecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasHelpFolder, ElementName=Root}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <iconPacks:PackIconMaterial Kind="HelpCircleOutline" Width="14" Height="14"
                                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Command="{Binding SwitchToSpecialVersionCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Margin="0,0,6,0"
                                ToolTip="{Binding Strings.TooltipSwitchSpecialVersion, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource CardSecondaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpdating, ElementName=Root}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <iconPacks:PackIconMaterial Kind="KeyVariant" Width="14" Height="14"
                                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Command="{Binding OpenFolderCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Margin="0,0,6,0"
                                ToolTip="{Binding Strings.TooltipOpenFolder, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource CardSecondaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUpdating, ElementName=Root}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"
                                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Command="{Binding UninstallCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Style="{StaticResource CardSecondaryButtonStyle}"
                                ToolTip="{Binding Strings.TooltipUninstall, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <iconPacks:PackIconMaterial Kind="TrashCanOutline" Width="14" Height="14"
                                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUninstalling, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse Width="13" Height="13" Margin="0,0,6,0"
                                 VerticalAlignment="Center"
                                 StrokeThickness="2"
                                 Stroke="{DynamicResource SecondaryFgDimBrush}"
                                 StrokeDashArray="13 7"
                                 StrokeDashCap="Round"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0" />
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <Trigger Property="IsVisible" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard x:Name="UninstallSpinStoryboard">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:0.9" RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="UninstallSpinStoryboard" />
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding Strings.StatusUninstalling, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                                   VerticalAlignment="Center" FontSize="11"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
    <Border CornerRadius="6" BorderThickness="2" BorderBrush="{DynamicResource PrimaryFgBrush}"
            IsHitTestVisible="False" Opacity="0" SnapsToDevicePixels="True">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.Downloading}">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard x:Name="PulseStoryboard">
                                <Storyboard RepeatBehavior="0:0:3" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="1" Duration="0:0:0.8" FillBehavior="Stop">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut" />
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
    </Grid>
</UserControl>
