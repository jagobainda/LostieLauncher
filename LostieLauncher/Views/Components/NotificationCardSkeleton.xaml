<UserControl x:Class="LostieLauncher.Views.Components.NotificationCardSkeleton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root">
    <!-- Mirrors the outer geometry of NotificationCardComponent: Border[OverlaySubtle, r8, p14, m0,0,0,10] -->
    <Border CornerRadius="8" Padding="14" Margin="0,0,0,10"
            Background="{DynamicResource OverlaySubtleBrush}" SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Accent stripe: 4px wide, r2, full height — mirrors the type-colored Border in real card -->
            <Border Grid.Column="0"
                    Style="{StaticResource SkeletonBlockStyle}"
                    Width="4" CornerRadius="2"
                    VerticalAlignment="Stretch" Margin="0,0,12,0" />

            <!-- Text: title bar + message bar — mirrors StackPanel[title FontSize=13 + message FontSize=12] -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Border Style="{StaticResource SkeletonBlockStyle}"
                        Height="14" CornerRadius="3"
                        Width="130" HorizontalAlignment="Left" />
                <Border Style="{StaticResource SkeletonBlockStyle}"
                        Height="11" CornerRadius="3"
                        Margin="0,4,0,0" />
            </StackPanel>

            <!-- Date placeholder — mirrors TextBlock[FontSize=11, dd MMM] -->
            <Border Grid.Column="2"
                    Style="{StaticResource SkeletonBlockStyle}"
                    Width="30" Height="11" CornerRadius="3"
                    VerticalAlignment="Top" Margin="8,2,0,0" />
        </Grid>
    </Border>
</UserControl>
