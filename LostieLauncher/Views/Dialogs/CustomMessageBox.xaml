<Window x:Class="LostieLauncher.Views.Dialogs.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:viewmodels="clr-namespace:LostieLauncher.ViewModels"
        mc:Ignorable="d"
        Height="220"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource PrimaryBgBrush}"
        BorderBrush="{DynamicResource PrimaryFgBrush}"
        BorderThickness="1"
        Icon="https://ericlostie-launcher.jagoba.dev/public/imgs/logo-launcher.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="Transparent"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <iconPacks:PackIconMaterial x:Name="TitleIcon"
                                           Kind="Update"
                                           Width="18" Height="18"
                                           Foreground="{DynamicResource PrimaryFgBrush}"
                                           VerticalAlignment="Center" />
                <TextBlock x:Name="TitleText"
                           Foreground="{DynamicResource SecondaryFgBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </StackPanel>
            <Button Click="CloseButton_Click"
                    HorizontalAlignment="Right"
                    Style="{StaticResource CloseButtonStyle}">
                <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12" />
            </Button>
        </Grid>

        <TextBlock x:Name="DescriptionText"
                   Grid.Row="1"
                   Foreground="{DynamicResource SecondaryFgBrush}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   Margin="20,0,20,0" />

        <Grid Grid.Row="2" Margin="20,0,20,20" VerticalAlignment="Bottom">
            <StackPanel x:Name="OkPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="{Binding Strings.BtnOk, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                        Width="100"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OkButton_Click" />
            </StackPanel>
            <StackPanel x:Name="YesNoPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Visibility="Collapsed">
                <Button Content="{Binding Strings.BtnYes, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                        Width="90"
                        Margin="0,0,8,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="YesButton_Click" />
                <Button Content="{Binding Strings.BtnNo, Source={x:Static viewmodels:SettingsViewModel.Instance}}"
                        Width="90"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="NoButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>