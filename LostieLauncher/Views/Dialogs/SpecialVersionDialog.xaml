<Window x:Class="LostieLauncher.Views.Dialogs.SpecialVersionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Height="250"
        Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource PrimaryBgBrush}"
        BorderBrush="{DynamicResource PrimaryFgBrush}"
        BorderThickness="1"
        Icon="https://ericlostie-launcher.jagoba.dev/public/imgs/logo-launcher.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="Transparent"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <iconPacks:PackIconMaterial Kind="Key"
                                           Width="18" Height="18"
                                           Foreground="{DynamicResource PrimaryFgBrush}"
                                           VerticalAlignment="Center" />
                <TextBlock x:Name="TitleText"
                           Foreground="{DynamicResource SecondaryFgBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </StackPanel>
            <Button Click="CloseButton_Click"
                    HorizontalAlignment="Right"
                    Style="{StaticResource CloseButtonStyle}">
                <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12" />
            </Button>
        </Grid>

        <StackPanel Grid.Row="1" Margin="20,0,20,0" VerticalAlignment="Center">
            <TextBlock x:Name="DescriptionText"
                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20" />

            <StackPanel Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <iconPacks:PackIconMaterial Kind="Key" Width="12" Height="12"
                                               Foreground="{DynamicResource SecondaryFgDimBrush}"
                                               VerticalAlignment="Center" />
                    <TextBlock x:Name="KeyLabel"
                               Foreground="{DynamicResource SecondaryFgDimBrush}"
                               FontSize="12" Margin="6,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBox x:Name="KeyBox"
                         Style="{StaticResource KeyBoxStyle}" />
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="2" Margin="20,0,20,20" VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="ConfirmButton"
                        Width="120"
                        Margin="0,0,8,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="ConfirmButton_Click" />
                <Button x:Name="CancelButton"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
