<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBgColor">#ffefd3</Color>
    <Color x:Key="SecondaryBgColor">#e8a772</Color>
    <Color x:Key="TertiaryBgColor">#ffefd3</Color>

    <Color x:Key="PrimaryFgColor">#3ecfcf</Color>
    <Color x:Key="PrimaryFgHoverColor">#343434</Color>
    <Color x:Key="PrimaryFgPressedColor">#f5e653</Color>

    <Color x:Key="SecondaryFgColor">#343434</Color>
    <Color x:Key="SecondaryFgDimColor">#88343434</Color>

    <Color x:Key="SuccessColor">#78c878</Color>

    <Color x:Key="OverlaySubtleColor">#1A000000</Color>
    <Color x:Key="OverlayLightColor">#22000000</Color>
    <Color x:Key="OverlayMutedColor">#33000000</Color>
    <Color x:Key="OverlayMediumColor">#55000000</Color>
    <Color x:Key="OverlayStrongColor">#88000000</Color>

    <SolidColorBrush x:Key="PrimaryBgBrush"       Color="{StaticResource PrimaryBgColor}" />
    <SolidColorBrush x:Key="SecondaryBgBrush"      Color="{StaticResource SecondaryBgColor}" />
    <SolidColorBrush x:Key="TertiaryBgBrush"       Color="{StaticResource TertiaryBgColor}" />
    <SolidColorBrush x:Key="PrimaryFgBrush"        Color="{StaticResource PrimaryFgColor}" />
    <SolidColorBrush x:Key="PrimaryFgHoverBrush"   Color="{StaticResource PrimaryFgHoverColor}" />
    <SolidColorBrush x:Key="PrimaryFgPressedBrush" Color="{StaticResource PrimaryFgPressedColor}" />
    <SolidColorBrush x:Key="SecondaryFgBrush"      Color="{StaticResource SecondaryFgColor}" />
    <SolidColorBrush x:Key="SecondaryFgDimBrush"   Color="{StaticResource SecondaryFgDimColor}" />
    <SolidColorBrush x:Key="SuccessBrush"          Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="OverlaySubtleBrush"    Color="{StaticResource OverlaySubtleColor}" />
    <SolidColorBrush x:Key="OverlayLightBrush"     Color="{StaticResource OverlayLightColor}" />
    <SolidColorBrush x:Key="OverlayMutedBrush"     Color="{StaticResource OverlayMutedColor}" />
    <SolidColorBrush x:Key="OverlayMediumBrush"    Color="{StaticResource OverlayMediumColor}" />
    <SolidColorBrush x:Key="OverlayStrongBrush"    Color="{StaticResource OverlayStrongColor}" />

</ResourceDictionary>