<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="PrimaryBgColor">#4d4949</Color>
    <Color x:Key="SecondaryBgColor">#b0dede</Color>
    <Color x:Key="PrimaryFgColor">#f08058</Color>
    <Color x:Key="SecondaryFgColor">#f3f7fa</Color>

    <SolidColorBrush x:Key="PrimaryBgBrush" Color="{StaticResource PrimaryBgColor}" />
    <SolidColorBrush x:Key="SecondaryBgBrush" Color="{StaticResource SecondaryBgColor}" />
    <SolidColorBrush x:Key="PrimaryFgBrush" Color="{StaticResource PrimaryFgColor}" />
    <SolidColorBrush x:Key="SecondaryFgBrush" Color="{StaticResource SecondaryFgColor}" />

</ResourceDictionary>
