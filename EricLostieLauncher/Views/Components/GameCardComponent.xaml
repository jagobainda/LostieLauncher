<UserControl x:Class="EricLostieLauncher.Views.Components.GameCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:EricLostieLauncher.Models"
             xmlns:converters="clr-namespace:EricLostieLauncher.Converters"
             xmlns:viewmodels="clr-namespace:EricLostieLauncher.ViewModels"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             x:Name="Root">

    <UserControl.Resources>
        <converters:EnumToVisibilityConverter x:Key="AvailableVisibility" TargetValue="Available" />
        <converters:EnumToVisibilityConverter x:Key="DownloadingVisibility" TargetValue="Downloading" />
        <converters:EnumToVisibilityConverter x:Key="DownloadedVisibility" TargetValue="Downloaded" />
        <converters:EnumToVisibilityConverter x:Key="UpdateAvailableVisibility" TargetValue="UpdateAvailable" />
        <converters:GameDownloadArgsConverter x:Key="GameDownloadArgsConverter" />

        <Style x:Key="CardAccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryFgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryFgHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryFgPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource OverlayMutedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="10,0" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayMediumBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayLightBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardDisabledButtonStyle" TargetType="Button" BasedOn="{StaticResource CardSecondaryButtonStyle}">
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource SecondaryBgBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,10" SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="80" Height="80"
                    CornerRadius="6"
                    Background="{DynamicResource TertiaryBgBrush}"
                    VerticalAlignment="Center"
                    ClipToBounds="True">
                <Grid>
                    <iconPacks:PackIconMaterial Kind="PokemonGo"
                                               Width="32" Height="32"
                                               Foreground="{DynamicResource OverlayMediumBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                        <iconPacks:PackIconMaterial.Style>
                            <Style TargetType="iconPacks:PackIconMaterial">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameLogo, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </iconPacks:PackIconMaterial.Style>
                    </iconPacks:PackIconMaterial>
                    <Image Source="{Binding GameLogo, ElementName=Root}"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GameLogo, ElementName=Root}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,16,0">
                <TextBlock Text="{Binding GameTitle, ElementName=Root}"
                           Foreground="{DynamicResource SecondaryFgBrush}"
                           FontSize="16"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Library}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <iconPacks:PackIconMaterial Kind="Harddisk" Width="12" Height="12"
                                               Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding GameSize, ElementName=Root}"
                               Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,14,0"
                               VerticalAlignment="Center" />

                    <iconPacks:PackIconMaterial Kind="Download" Width="12" Height="12"
                                               Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalDownloads, ElementName=Root}"
                               Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,14,0"
                               VerticalAlignment="Center" />

                    <iconPacks:PackIconMaterial Kind="TagOutline" Width="12" Height="12"
                                               Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LatestVersion, ElementName=Root}"
                               Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Margin="0,6,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Games}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="TagOutline" Width="12" Height="12"
                                                   Foreground="{DynamicResource SecondaryFgDimBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding InstalledVersion, ElementName=Root}"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}" FontSize="12" Margin="4,0,0,0"
                                   VerticalAlignment="Center" />

                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUpdate, ElementName=Root}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <iconPacks:PackIconMaterial Kind="ArrowRight" Width="10" Height="10"
                                                       Foreground="{DynamicResource PrimaryFgBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,8,0" />
                            <TextBlock Text="{Binding UpdateVersion, ElementName=Root}"
                                       Foreground="{DynamicResource PrimaryFgBrush}" FontSize="12"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Grid Margin="0,8,0,0" Height="4">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DownloadStatus, ElementName=Root}" Value="{x:Static models:GameDownloadStatus.Downloading}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Border Background="{DynamicResource OverlayLightBrush}" CornerRadius="2" />
                    <Border Background="{DynamicResource PrimaryFgBrush}" CornerRadius="2"
                            HorizontalAlignment="Left"
                            Width="{Binding DownloadProgress, ElementName=Root}"
                            MaxWidth="300" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Library}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Button Command="{Binding DownloadCommand, ElementName=Root}"
                            Style="{StaticResource CardAccentButtonStyle}"
                            Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource AvailableVisibility}}">
                        <Button.CommandParameter>
                            <MultiBinding Converter="{StaticResource GameDownloadArgsConverter}">
                                <Binding Path="GameId" ElementName="Root" />
                                <Binding Path="LatestVersion" ElementName="Root" />
                            </MultiBinding>
                        </Button.CommandParameter>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Download" Width="13" Height="13"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Strings.BtnDownload, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource CardDisabledButtonStyle}"
                            Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource DownloadingVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ProgressDownload" Width="13" Height="13"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Strings.BtnDownloading, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource CardDisabledButtonStyle}"
                            Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource DownloadedVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check" Width="13" Height="13"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Strings.BtnDownloaded, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding DownloadCommand, ElementName=Root}"
                            Style="{StaticResource CardAccentButtonStyle}"
                            Visibility="{Binding DownloadStatus, ElementName=Root, Converter={StaticResource UpdateAvailableVisibility}}">
                        <Button.CommandParameter>
                            <MultiBinding Converter="{StaticResource GameDownloadArgsConverter}">
                                <Binding Path="GameId" ElementName="Root" />
                                <Binding Path="LatestVersion" ElementName="Root" />
                            </MultiBinding>
                        </Button.CommandParameter>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Update" Width="13" Height="13"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Strings.BtnUpdate, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CardMode, ElementName=Root}" Value="{x:Static models:GameCardMode.Games}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding PlayCommand, ElementName=Root}"
                                Style="{StaticResource CardAccentButtonStyle}"
                                Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Play" Width="13" Height="13"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Strings.BtnPlay, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding UpdateCommand, ElementName=Root}"
                                Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource CardSecondaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasUpdate, ElementName=Root}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Update" Width="13" Height="13"
                                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Strings.BtnUpdate, Source={x:Static viewmodels:SettingsViewModel.Instance}}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding OpenFolderCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Style="{StaticResource CardSecondaryButtonStyle}"
                                Margin="0,0,6,0"
                                ToolTip="{Binding Strings.TooltipOpenFolder, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="14" Height="14"
                                                       VerticalAlignment="Center" />
                        </Button>

                        <Button Command="{Binding UninstallCommand, ElementName=Root}"
                                CommandParameter="{Binding GameTitle, ElementName=Root}"
                                Style="{StaticResource CardSecondaryButtonStyle}"
                                ToolTip="{Binding Strings.TooltipUninstall, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                            <iconPacks:PackIconMaterial Kind="TrashCanOutline" Width="14" Height="14"
                                                       VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
