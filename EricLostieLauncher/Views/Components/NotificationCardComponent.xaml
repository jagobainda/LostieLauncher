<UserControl x:Class="EricLostieLauncher.Views.Components.NotificationCardComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:EricLostieLauncher.Converters"
             mc:Ignorable="d"
             x:Name="Root">

    <UserControl.Resources>
        <converters:NotificationTypeToBrushConverter x:Key="TypeToBrushConverter" />
    </UserControl.Resources>

    <Border CornerRadius="8" Padding="14" Margin="0,0,0,10"
            Background="{DynamicResource OverlaySubtleBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Type indicator -->
            <Border Grid.Column="0" Width="4" CornerRadius="2"
                    VerticalAlignment="Stretch" Margin="0,0,12,0"
                    Background="{Binding NotificationType, ElementName=Root, Converter={StaticResource TypeToBrushConverter}}" />

            <!-- Content -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Foreground="{DynamicResource SecondaryFgBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Message, ElementName=Root}"
                           Foreground="{DynamicResource SecondaryFgDimBrush}"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Date -->
            <TextBlock Grid.Column="2"
                       Text="{Binding Date, ElementName=Root, StringFormat='{}{0:dd MMM}'}"
                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                       FontSize="11" VerticalAlignment="Top" Margin="8,2,0,0" />
        </Grid>
    </Border>
</UserControl>
