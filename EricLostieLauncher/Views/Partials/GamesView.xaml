<UserControl x:Class="EricLostieLauncher.Views.Partials.GamesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:EricLostieLauncher.ViewModels"
             xmlns:components="clr-namespace:EricLostieLauncher.Views.Components"
             xmlns:models="clr-namespace:EricLostieLauncher.Models"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             d:DataContext="{d:DesignInstance Type=viewmodels:GamesViewModel}"
             mc:Ignorable="d">
    <Grid>
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="Pokeball"
                                           Width="48" Height="48"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryFgBrush}"
                                           RenderTransformOrigin="0.5,0.5">
                    <iconPacks:PackIconMaterial.RenderTransform>
                        <RotateTransform x:Name="PokeballRotation" />
                    </iconPacks:PackIconMaterial.RenderTransform>
                </iconPacks:PackIconMaterial>
                <TextBlock Text="Cargando juegos instalados..."
                           Foreground="{DynamicResource SecondaryFgDimBrush}"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,16,0,0" />
            </StackPanel>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="PokeballRotation"
                                             Storyboard.TargetProperty="Angle"
                                             From="0" To="360" Duration="0:0:1" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <ItemsControl ItemsSource="{Binding InstalledGames}" Margin="20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:InstalledGameInfo}">
                        <components:GameCardComponent
                            CardMode="Games"
                            GameTitle="{Binding Nombre}"
                            InstalledVersion="{Binding InstalledVersion}"
                            HasUpdate="{Binding HasUpdate}"
                            UpdateVersion="{Binding UpdateVersion}"
                            PlayCommand="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            OpenFolderCommand="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            UninstallCommand="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
