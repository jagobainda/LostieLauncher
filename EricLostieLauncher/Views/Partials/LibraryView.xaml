<UserControl x:Class="EricLostieLauncher.Views.Partials.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:EricLostieLauncher.ViewModels"
             xmlns:components="clr-namespace:EricLostieLauncher.Views.Components"
             xmlns:models="clr-namespace:EricLostieLauncher.Models"
             d:DataContext="{d:DesignInstance Type=viewmodels:LibraryViewModel}"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <components:GameCardComponent
                CardMode="Library"
                GameId="minecraft"
                GameTitle="Minecraft"
                GameSize="1.2 GB"
                TotalDownloads="12.345"
                LatestVersion="1.21.4"
                DownloadStatus="Available"
                DownloadCommand="{Binding StartDownloadCommand}" />

            <components:GameCardComponent
                CardMode="Library"
                GameId="terraria"
                GameTitle="Terraria"
                GameSize="200 MB"
                TotalDownloads="8.910"
                LatestVersion="1.4.4"
                DownloadStatus="Downloading"
                DownloadProgress="150"
                DownloadCommand="{Binding StartDownloadCommand}" />

            <components:GameCardComponent
                CardMode="Library"
                GameId="stardew-valley"
                GameTitle="Stardew Valley"
                GameSize="500 MB"
                TotalDownloads="5.678"
                LatestVersion="1.6.0"
                DownloadStatus="Downloaded"
                DownloadCommand="{Binding StartDownloadCommand}" />

            <components:GameCardComponent
                CardMode="Library"
                GameId="among-us"
                GameTitle="Among Us"
                GameSize="350 MB"
                TotalDownloads="99.999"
                LatestVersion="2024.11.26"
                DownloadStatus="UpdateAvailable"
                DownloadCommand="{Binding StartDownloadCommand}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
