<UserControl x:Class="EricLostieLauncher.Views.Partials.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:EricLostieLauncher.ViewModels"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="44" Height="24" CornerRadius="12"
                                Background="{DynamicResource OverlayMutedBrush}" SnapsToDevicePixels="True">
                            <Border x:Name="Thumb" Width="18" Height="18" CornerRadius="9"
                                    Background="{DynamicResource SecondaryFgBrush}"
                                    HorizontalAlignment="Left" Margin="3,0,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource PrimaryFgBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource OverlayMutedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="12,0" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayMediumBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayLightBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TertiaryBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="10,7" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,20,20,4">

            <TextBlock Text="{Binding Strings.SettingsGeneral}"
                       Foreground="{DynamicResource PrimaryFgBrush}"
                       FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8" />

            <Border Background="{DynamicResource SecondaryBgBrush}" CornerRadius="6"
                    SnapsToDevicePixels="True" Margin="0,0,0,24">
                <StackPanel>

                    <Grid Margin="16,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Launch" Width="16" Height="16"
                                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding Strings.SettingsStartWithWindows}"
                                       Foreground="{DynamicResource SecondaryFgBrush}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding StartWithWindows}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Border Height="1" Background="{DynamicResource OverlayLightBrush}" Margin="16,0" />

                    <Grid Margin="16,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="16" Height="16"
                                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding Strings.SettingsStartMinimized}"
                                       Foreground="{DynamicResource SecondaryFgBrush}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding StartMinimized}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Border Height="1" Background="{DynamicResource OverlayLightBrush}" Margin="16,0" />

                    <Grid Margin="16,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Update" Width="16" Height="16"
                                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding Strings.SettingsAutoUpdate}"
                                       Foreground="{DynamicResource SecondaryFgBrush}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                                  IsChecked="{Binding AutoUpdate}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Border Height="1" Background="{DynamicResource OverlayLightBrush}" Margin="16,0" />

                    <Grid Margin="16,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16"
                                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding CurrentVersion}"
                                       Foreground="{DynamicResource SecondaryFgBrush}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Content="{Binding Strings.SettingsCheckForUpdates}"
                                Command="{Binding CheckForUpdatesCommand}"
                                Style="{StaticResource SettingsButtonStyle}"
                                HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                    <Border Height="1" Background="{DynamicResource OverlayLightBrush}" Margin="16,0" />

                    <StackPanel Margin="16,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <iconPacks:PackIconMaterial Kind="FolderDownload"
                                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding Strings.SettingsDownloadDir}"
                                       Foreground="{DynamicResource SecondaryFgBrush}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding DownloadDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SettingsTextBoxStyle}"
                                     IsReadOnly="True" />
                            <Button Grid.Column="1"
                                    Content="{Binding Strings.BtnBrowse}"
                                    Command="{Binding BrowseDownloadDirectoryCommand}"
                                    Style="{StaticResource SettingsButtonStyle}"
                                    Margin="8,0,0,0" />
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Strings.SettingsAppearance}"
                       Foreground="{DynamicResource PrimaryFgBrush}"
                       FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8" />

            <Border Background="{DynamicResource SecondaryBgBrush}" CornerRadius="6"
                    SnapsToDevicePixels="True" Margin="0,0,0,0">
                <StackPanel>

                    <Grid Margin="16,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Translate"
                                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding Strings.SettingsLanguage}"
                                       Foreground="{DynamicResource SecondaryFgBrush}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <ComboBox Style="{StaticResource SettingsComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItemStyle}"
                                  ItemsSource="{x:Static viewmodels:SettingsViewModel.LanguageOptions}"
                                  SelectedItem="{Binding Language}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource OverlayLightBrush}" Margin="16,0" />

                    <Grid Margin="16,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Palette" Width="16" Height="16"
                                                       Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding Strings.SettingsTheme}"
                                       Foreground="{DynamicResource SecondaryFgBrush}"
                                       FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <ComboBox Style="{StaticResource SettingsComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource SettingsComboBoxItemStyle}"
                                  ItemsSource="{x:Static viewmodels:SettingsViewModel.ThemeOptions}"
                                  SelectedItem="{Binding Theme}"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>

                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
