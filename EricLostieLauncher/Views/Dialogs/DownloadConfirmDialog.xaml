<Window x:Class="EricLostieLauncher.Views.Dialogs.DownloadConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:viewmodels="clr-namespace:EricLostieLauncher.ViewModels"
        mc:Ignorable="d"
        Height="420"
        Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource PrimaryBgBrush}"
        BorderBrush="{DynamicResource PrimaryFgBrush}"
        BorderThickness="1"
        Icon="https://ericlostie-launcher.jagoba.dev/public/imgs/logo-launcher.png">

    <Window.Resources>
        <Style x:Key="KeyBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TertiaryBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="10,8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="Transparent"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <iconPacks:PackIconMaterial Kind="Download"
                                           Width="18" Height="18"
                                           Foreground="{DynamicResource PrimaryFgBrush}"
                                           VerticalAlignment="Center" />
                <TextBlock x:Name="TitleText"
                           Foreground="{DynamicResource SecondaryFgBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </StackPanel>
            <Button Click="CloseButton_Click"
                    HorizontalAlignment="Right"
                    Style="{StaticResource CloseButtonStyle}">
                <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,0,20,0">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="90" Height="72"
                            CornerRadius="6"
                            Background="{DynamicResource TertiaryBgBrush}"
                            VerticalAlignment="Top"
                            ClipToBounds="True"
                            Padding="5">
                        <Grid>
                            <iconPacks:PackIconMaterial x:Name="GameLogoFallback"
                                                       Kind="Pokeball"
                                                       Width="28" Height="28"
                                                       Foreground="{DynamicResource OverlayMediumBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                            <Image x:Name="GameLogoImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Top">
                        <TextBlock x:Name="GameTitleText"
                                   Foreground="{DynamicResource SecondaryFgBrush}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="DescriptionText"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   MaxHeight="100" />
                        <Button x:Name="ViewPageButton"
                                Margin="0,6,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource LinkButtonStyle}"
                                Click="ViewPageButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="OpenInNew" Width="11" Height="11"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                                           Foreground="{DynamicResource PrimaryFgBrush}" />
                                <TextBlock x:Name="ViewPageText"
                                           Foreground="{DynamicResource PrimaryFgBrush}"
                                           FontSize="12"
                                           TextDecorations="Underline" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock x:Name="PathLabel"
                               Foreground="{DynamicResource SecondaryFgDimBrush}"
                               FontSize="12"
                               Margin="0,0,0,4" />
                    <Border Background="{DynamicResource TertiaryBgBrush}"
                            CornerRadius="4"
                            Padding="10,8">
                        <TextBlock x:Name="DownloadPathText"
                                   Foreground="{DynamicResource SecondaryFgBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                    </Border>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Harddisk" Width="14" Height="14"
                                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="GameSizeLabel"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                   FontSize="12" Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="GameSizeText"
                                   Foreground="{DynamicResource SecondaryFgBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="DatabaseCheck" Width="14" Height="14"
                                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="FreeSpaceLabel"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                   FontSize="12" Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="FreeSpaceText"
                                   Foreground="{DynamicResource SecondaryFgBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="KeySection" Margin="0,30,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <iconPacks:PackIconMaterial Kind="Key" Width="12" Height="12"
                                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="KeyLabel"
                                   Foreground="{DynamicResource SecondaryFgDimBrush}"
                                   FontSize="12" Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBox x:Name="KeyBox"
                             Style="{StaticResource KeyBoxStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="20,0,20,20" VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="DownloadButton"
                        Width="120"
                        Margin="0,0,8,0"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="DownloadButton_Click" />
                <Button x:Name="CancelButton"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
