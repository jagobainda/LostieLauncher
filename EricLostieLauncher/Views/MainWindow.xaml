<Window x:Class="EricLostieLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EricLostieLauncher"
        xmlns:viewmodels="clr-namespace:EricLostieLauncher.ViewModels"
        xmlns:partials="clr-namespace:EricLostieLauncher.Views.Partials"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Height="650"
        Width="1000"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="{DynamicResource PrimaryBgBrush}"
        BorderBrush="{DynamicResource PrimaryFgBrush}"
        BorderThickness="1"
        Icon="https://ericlostie-launcher.jagoba.dev/public/imgs/logo-launcher.png"
        Title="EricLostie Launcher">

    <Window.Resources>
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayMediumBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgDimBrush}" />
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="ActiveIndicator"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource PrimaryFgBrush}"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayLightBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryFgBrush}" />
                    <Setter Property="Background" Value="{DynamicResource OverlaySubtleBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryFgDimBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="60" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayLightBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
            <partials:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:GamesViewModel}">
            <partials:GamesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:LibraryViewModel}">
            <partials:LibraryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
            <partials:SettingsView />
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="Transparent"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <Image Source="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Icon}"
                       Width="22" Height="22"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="{Binding CurrentTitle}"
                           Foreground="{DynamicResource SecondaryFgBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="MinimizeButton_Click"
                        Style="{StaticResource TitleBarButtonStyle}">
                    <iconPacks:PackIconMaterial Kind="WindowMinimize" Width="12" Height="12" />
                </Button>
                <Button Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}">
                    <iconPacks:PackIconMaterial Kind="WindowClose" Width="12" Height="12" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource SecondaryBgBrush}" Margin="15">
                <StackPanel VerticalAlignment="Top">
                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsHomeActive, Mode=OneWay}"
                                 Command="{Binding NavigateToHomeCommand}"
                                 ToolTip="{Binding Strings.TitleHome, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                        <iconPacks:PackIconMaterial Kind="Home" Width="22" Height="22" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsGamesActive, Mode=OneWay}"
                                 Command="{Binding NavigateToGamesCommand}"
                                 ToolTip="{Binding Strings.TitleGames, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                        <iconPacks:PackIconMaterial Kind="Play" Width="22" Height="22" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 GroupName="Navigation"
                                 IsChecked="{Binding IsLibraryActive, Mode=OneWay}"
                                 Command="{Binding NavigateToLibraryCommand}"
                                 ToolTip="{Binding Strings.TitleLibrary, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                        <iconPacks:PackIconMaterial Kind="Download" Width="22" Height="22" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                    </RadioButton>
                    <Button Style="{StaticResource NavActionButtonStyle}"
                            Command="{Binding RefreshDataCommand}"
                            ToolTip="{Binding Strings.TooltipRefresh, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="22" Height="22" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom">
                    <RadioButton Style="{StaticResource NavItemStyle}"
                                 GroupName="Navigation"
                                 Command="{Binding NavigateToSettingsCommand}"
                                 ToolTip="{Binding Strings.TitleSettings, Source={x:Static viewmodels:SettingsViewModel.Instance}}">
                        <iconPacks:PackIconMaterial Kind="Cog" Width="22" Height="22" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                    </RadioButton>
                </StackPanel>
            </Grid>

            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="0, 15, 15, 15" />
        </Grid>
    </Grid>
</Window>
